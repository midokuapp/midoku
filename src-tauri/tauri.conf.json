{
    "productName": "Midoku",
    "version": "0.0.0",
    "identifier": "app.midoku",
    "build": {
        "frontendDist": "../src-ui/dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "trunk serve",
        "beforeBuildCommand": "trunk build"
    },
    "app": {
        "windows": [
            {
                "title": "Midoku",
                "width": 600,
                "height": 1000,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
